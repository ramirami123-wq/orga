ng: 12px; margin: 12px 0; }\n    .gz-promo-inner { gap: 10px; justify-content: center; }\n    .gz-promo-text { display: none; }\n    .gz-promo-timer-label { font-size: 12px; }\n  }\n</style>\n\n<div class=\"gz-promo\">\n  <div class=\"gz-promo-inner\">\n    <div class=\"gz-promo-sale\">\n      <span class=\"gz-promo-badge\">30% OFF</span>\n      <span class=\"gz-promo-text\">Limited-time sale</span>\n    </div>\n    <div class=\"gz-promo-timer\">\n      <span class=\"gz-promo-timer-label\">Ends in</span>\n      <span class=\"gz-promo-timer-value\" id=\"gz-promo-h\">12</span>\n      <span>:</span>\n      <span class=\"gz-promo-timer-value\" id=\"gz-promo-m\">00</span>\n      <span>:</span>\n      <span class=\"gz-promo-timer-value\" id=\"gz-promo-s\">00</span>\n    </div>\n    <div class=\"gz-promo-reviews\">\n      <span class=\"gz-promo-stars\">★★★★★</span>\n      <span class=\"gz-promo-rating\">4.8</span>\n      <span class=\"gz-promo-rating-meta\">(312 reviews)</span>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  function pad(n) { return n.toString().padStart(2, '0'); }\n  function tick() {\n    var stored = sessionStorage.getItem('gz_promo_end');\n    var end;\n    if (stored) {\n      end = parseInt(stored, 10);\n      if (isNaN(end) || end < Date.now()) {\n        end = Date.now() + 12 * 60 * 60 * 1000;\n        sessionStorage.setItem('gz_promo_end', String(end));\n      }\n    } else {\n      end = Date.now() + 12 * 60 * 60 * 1000;\n      sessionStorage.setItem('gz_promo_end', String(end));\n    }\n    var diff = Math.max(0, end - Date.now());\n    var h = Math.floor(diff / (1000 * 60 * 60));\n    var m = Math.floor((diff / (1000 * 60)) % 60);\n    var s = Math.floor((diff / 1000) % 60);\n    var hEl = document.getElementById('gz-promo-h');\n    var mEl = document.getElementById('gz-promo-m');\n    var sEl = document.getElementById('gz-promo-s');\n    if (hEl) hEl.textContent = pad(h);\n    if (mEl) mEl.textContent = pad(m);\n    if (sEl) sEl.textContent = pad(s);\n  }\n  tick();\n  setInterval(tick, 1000);\n})();\n</script>"
